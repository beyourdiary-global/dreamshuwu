RewriteEngine On

# 1. Dynamic Routing (Must go BEFORE blocking rules)
# Chapter Management Dynamic Routing
RewriteRule ^author/novel/([0-9]+)/chapters/?$ src/pages/author/chapter-management/index.php?novel_id=$1 [QSA,L]

# 2. Security: Block direct access to "src", EXCEPT for specific files
RewriteCond %{REQUEST_URI} !^/src/pages/category/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/tags/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/meta/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/webSetting/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/admin/page-action/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/admin/page-information-list/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/admin/user-role/index\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/author/author-verification/api\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/author/email-template/api\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/author/novel-management/api\.php$
RewriteCond %{REQUEST_URI} !^/src/pages/author/chapter-management/api\.php$
# Allow the internal router target to be accessed
RewriteCond %{REQUEST_URI} !^/src/pages/author/chapter-management/index\.php$

# If none of the files above match, block access to anything inside src/
RewriteRule ^src/ - [F,L]

# 3. Error Pages
ErrorDocument 404 /error404.php